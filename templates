<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Predictor 4.0 Pro</title>
    <style>
        body { background: #050505; color: #00ff41; font-family: sans-serif; text-align: center; margin: 0; padding: 10px; }
        .header { font-size: 22px; font-weight: bold; margin: 20px 0; text-shadow: 0 0 10px #00ff41; }
        .game-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 10px; padding: 10px; }
        .game-card { background: #111; border: 1px solid #333; border-radius: 10px; padding: 15px; cursor: pointer; transition: 0.3s; }
        .game-card:hover { border-color: #00ff41; box-shadow: 0 0 10px #00ff41; }
        .game-card img { width: 50px; height: 50px; margin-bottom: 10px; }
        .active-game { border: 2px solid #00ff41; }
        #prediction-area { margin-top: 20px; display: none; background: #111; padding: 20px; border-radius: 15px; border: 1px solid #00ff41; }
        .btn { background: #00ff41; color: #000; border: none; padding: 10px 20px; border-radius: 5px; font-weight: bold; margin-top: 15px; }
    </style>
</head>
<body>
    <div class="header">PREDICTOR 4.0 AI PRO</div>
    
    <div id="game-selection">
        <p>SELECT YOUR GAME</p>
        <div class="game-grid">
            <div class="game-card" onclick="selectGame('55 CLUB')">55 CLUB</div>
            <div class="game-card" onclick="selectGame('LOTTERY 7')">LOTTERY 7</div>
            <div class="game-card" onclick="selectGame('TIRANGA')">TIRANGA</div>
            <div class="game-card" onclick="selectGame('JALWA')">JALWA GAME</div>
        </div>
    </div>

    <div id="prediction-area">
        <h2 id="current-game-name">--</h2>
        <p>Period: <span id="period-num">Syncing...</span></p>
        <h1 id="result-display">READY</h1>
        <button class="btn" onclick="generateResult()">GET RESULT</button>
        <button class="btn" style="background:red; color:white;" onclick="location.reload()">BACK</button>
    </div>

    <script>
        function selectGame(name) {
            document.getElementById('game-selection').style.display = 'none';
            document.getElementById('prediction-area').style.display = 'block';
            document.getElementById('current-game-name').innerText = name;
            startPeriodSync();
        }

        function startPeriodSync() {
            setInterval(() => {
                const now = new Date();
                const totalMin = (now.getHours() * 60) + now.getMinutes();
                const period = new Date().toISOString().slice(0,10).replace(/-/g,'') + "1000" + (9671 + totalMin);
                document.getElementById('period-num').innerText = period;
            }, 1000);
        }

        function generateResult() {
            document.getElementById('result-display').innerText = "WAIT...";
            setTimeout(() => {
                const res = Math.random() > 0.5 ? "BIG 🔴" : "SMALL 🟢";
                document.getElementById('result-display').innerText = res;
            }, 1000);
        }
    </script>
</body>
</html>
